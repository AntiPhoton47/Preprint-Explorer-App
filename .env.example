GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Backend runtime
PORT=3001
DATABASE_URL="postgres://postgres:postgres@localhost:5432/preprint_explorer"
ENABLE_POSTGRES_APP_STORE=1
INITIAL_ADMIN_EMAIL="aris.thorne@uzh.ch"
BACKUP_RETENTION_COUNT=10
BACKUP_UPLOAD_PROVIDER="generic-webhook"
BACKUP_UPLOAD_URL=""
BACKUP_UPLOAD_METHOD="PUT"
BACKUP_UPLOAD_BEARER_TOKEN=""
BACKUP_S3_BUCKET=""
BACKUP_S3_REGION="us-east-1"
BACKUP_S3_ENDPOINT=""
BACKUP_S3_PREFIX="preprint-explorer"
BACKUP_S3_ACCESS_KEY_ID=""
BACKUP_S3_SECRET_ACCESS_KEY=""
BACKUP_S3_FORCE_PATH_STYLE=0

# Public origin / auth
APP_URL="http://localhost:3001"
WEBAUTHN_RP_ID="localhost"
WEBAUTHN_ORIGIN="http://localhost:3001"
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:no-reply@example.com"

# Email delivery
EMAIL_FROM="Preprint Explorer <no-reply@example.com>"
SMTP_URL="smtp://user:pass@smtp.example.com:587"
DIGEST_INTERVAL_MS=300000
DIGEST_TIMEZONE="UTC"
MONITORING_PROVIDER="generic-webhook"
MONITORING_WEBHOOK_URL=""
MONITORING_WEBHOOK_TOKEN=""

# Moderation policy
MODERATION_AUTO_ASSIGN=1
MODERATION_AUTO_ESCALATE_REASONS="harassment,misinformation,copyright"
MODERATION_TARGET_REPORT_ESCALATION_THRESHOLD=3
